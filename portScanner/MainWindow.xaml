<Window x:Class="portScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:portScanner"
        mc:Ignorable="d"
        Title="Port Scanner" Height="700" Width="1300"
        MinHeight="700" MinWidth="900"
        Background="#1E1E2E" Icon="pack://application:,,,/img/logo.png">
    <Window.Resources>
        <!-- Colori predefiniti -->
        <SolidColorBrush x:Key="PrimaryBg" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="SecondaryBg" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="AccentColor" Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentHover" Color="#6D28D9"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#374151"/>
        <!-- Proprietà predefinite per gli oggetti -->
        <!-- Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#4B5563"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopBarButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#374151"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4B5563"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#DC2626"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- GroupBox -->
        <Style x:Key="GroupBox" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#7C3AED"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border CornerRadius="8"
                        Background="#2A2A3E"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel>
                                <!-- Header -->
                                <Border Background="#374151" CornerRadius="8,8,0,0">
                                    <ContentPresenter ContentSource="Header"
                                          Margin="12,10,12,6"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <!-- Linea separatrice -->
                                <Rectangle Height="1" Fill="#374151" Margin="0,0,0,8"/>
                                <!-- Contenuto -->
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Label -->
        <Style x:Key="FormLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
        </Style>
        <!-- TextBox -->
        <Style x:Key="TextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}">
                            <!-- ScrollViewer obbligatorio per la txtbox -->
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Combobox -->
        <Style x:Key="ComboBox" TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#FF16162A"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!-- Checkbox -->
        <Style x:Key="CheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- Toolbar top -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="30"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>
        <!-- ===== TOP TOOLBAR ===== -->
        <Border Grid.Row="0" Background="#16162A" BorderBrush="#374151" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Logo / Titolo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Image Source="pack://application:,,,/img/logo.png"  Width="35"/>
                    <TextBlock Text="Port scanner" Foreground="#F1F5F9" FontSize="20" VerticalAlignment="Center" FontWeight="Bold" Margin="10" />
                </StackPanel>
                <!-- Pulsanti toolbar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- x:Name="BtnClearHistory" — pulisce la cronologia -->
                    <Button x:Name="BtnClearHistory" Content="🗑 Cronologia" Style="{StaticResource TopBarButton}" Margin="5"/>
                    <!-- x:Name="BtnExportJSON" — export JSON -->
                    <Button x:Name="BtnExportJSON" Content="📄 JSON" Style="{StaticResource TopBarButton}" Margin="5"/>
                    <!-- x:Name="BtnExportCSV" — export CSV -->
                    <Button x:Name="BtnExportCSV" Content="📊 CSV" Style="{StaticResource TopBarButton}" Margin="5" Click="BtnExportCSV_Click"/>
                    <!-- x:Name="BtnAbout" — finestra about -->
                    <Button x:Name="BtnAbout" Content="ℹ" Style="{StaticResource TopBarButton}" Margin="5"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- ========== PANNELLO SINISTRO: PARAMETRI ========== -->
            <Grid Grid.Column="0" Background="#1A1A2E" Cursor="">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <!-- Inserimento parametri -->
                <Border Grid.Row="0" BorderBrush="#374151" BorderThickness="0,0,1,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <StackPanel Margin="10,0,10,0">
                            <!-- TARGET GROUP -->
                            <GroupBox Header="🎯  TARGET" Foreground="#7C3AED" FontWeight="SemiBold" FontSize="12" Style="{StaticResource GroupBox}">
                                <StackPanel>
                                    <Label Content="IP / HOSTNAME" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="TxtTarget" Style="{StaticResource TextBox}"
                                         Text="192.168.1.1"
                                         ToolTip="Inserisci IP (es. 192.168.1.1) o hostname (es. google.com)"/>
                                </StackPanel>
                            </GroupBox>
                            <!-- PORT GROUP -->
                            <GroupBox Header="🔌  PORTE" Foreground="#7C3AED" FontWeight="SemiBold" FontSize="12" Style="{StaticResource GroupBox}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <Label Content="PORTA D'INIZIO" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="TxtPortStart" Style="{StaticResource TextBox}"
                                            Text="1" ToolTip="Porta iniziale (1-65535)"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="—" Foreground="#94A3B8"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <StackPanel Grid.Column="2">
                                            <Label Content="PORTA DI FINE" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="TxtPortEnd" Style="{StaticResource TextBox}"
                                            Text="1024" ToolTip="Porta finale (1-65535)"/>
                                        </StackPanel>
                                    </Grid>
                                    <Label Content="PRESET PORTE" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="CmbPortPreset" Style="{StaticResource ComboBox}" Margin="0,0,0,8">
                                        <ComboBoxItem Content="Personalizzato" IsSelected="True"/>
                                        <ComboBoxItem Content="Well-Known (1-1023)"/>
                                        <ComboBoxItem Content="Registrate (1024-49151)"/>
                                        <ComboBoxItem Content="Top 100 comuni"/>
                                        <ComboBoxItem Content="Tutte (1-65535)"/>
                                        <ComboBoxItem Content="Web (80, 443, 8080, 8443)"/>
                                        <ComboBoxItem Content="Database (1433, 1521, 3306, 5432, 27017)"/>
                                    </ComboBox>
                                    <!-- Porte personalizzate -->
                                    <Label Content="PORTE SPECIFICHE (virgola)" Style="{StaticResource FormLabel}"/>
                                    <!-- x:Name="TxtCustomPorts" — lista manuale di porte specifiche -->
                                    <TextBox x:Name="TxtCustomPorts" Style="{StaticResource TextBox}"
                                         ToolTip="Es: 22,80,443,3306"/>

                                    <Separator Background="#374151" Margin="0,10"/>

                                    <!-- Protocolli -->
                                    <Label Content="PROTOCOLLI" Style="{StaticResource FormLabel}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- x:Name="ChkTCP" — abilita scansione TCP -->
                                        <CheckBox x:Name="ChkTCP" Content="TCP" Style="{StaticResource CheckBox}"
                                              IsChecked="True" Margin="0,0,16,0"/>
                                        <!-- x:Name="ChkUDP" — abilita scansione UDP -->
                                        <CheckBox x:Name="ChkUDP" Content="UDP" Style="{StaticResource CheckBox}"/>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="🚀 Velocità" Foreground="#7C3AED" FontWeight="SemiBold" FontSize="12" Style="{StaticResource GroupBox}">
                                <StackPanel>
                                    <Label x:Name="LblThreadValue" Content="Thread" Style="{StaticResource FormLabel}"></Label>
                                    <Slider x:Name="SldThread" Minimum="1" Maximum="10" Value="1" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SldThread_Change"></Slider>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Bottoni di Avvio/Stop scansione -->
                <Grid Grid.Row="1" Margin="10,5,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnStartScan" Grid.Column="0" Content="▶ AVVIA" MaxHeight="45" MinHeight="40" FontSize="14" Style="{StaticResource PrimaryButton}" Padding="0,10" Click="BtnStartScan_Click" Cursor="Hand"/>
                    <Button x:Name="BtnStopScan" Grid.Column="2" Content="⏹ FERMA" MaxHeight="45" MinHeight="40" FontSize="14" Style="{StaticResource DangerButton}" Cursor="Hand" Padding="0,10" IsEnabled="False" Click="BtnStopScan_Click"/>
                </Grid>
            </Grid>
            <!-- ========== PANNELLO DESTRO: RISULTATI ========== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Barra progress + stats -->
                    <RowDefinition Height="*"/>
                    <!-- Tab selector -->
                    <RowDefinition Height="auto"/>
                    <!-- Contenuto tab -->
                    <RowDefinition Height="Auto"/>
                    <!-- Barra filtri -->
                </Grid.RowDefinitions>

                <!-- PROGRESS E STATISTICHE -->
                <Border Grid.Row="0" Background="#16162A" Padding="16,10" BorderBrush="#374151" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Info scansione corrente -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <!-- x:Name="LblScanStatus" — testo stato corrente scansione -->
                                <TextBlock x:Name="LblScanStatus" Text="In attesa..." Foreground="#94A3B8" FontSize="13"/>
                                <!-- x:Name="LblCurrentPort" — porta attualmente in scansione -->
                                <TextBlock x:Name="LblCurrentPort" Text="" Foreground="#7C3AED" FontSize="13" Margin="8,0,0,0"/>
                            </StackPanel>
                            <!-- x:Name="LblElapsedTime" — tempo trascorso dalla scansione -->
                            <TextBlock x:Name="LblElapsedTime" Grid.Column="1" Text="00:00:00"
                           Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Progress Bar -->
                        <!-- x:Name="PbarScanProgress" — barra avanzamento scansione -->
                        <ProgressBar x:Name="PbarScanProgress" Grid.Row="1" Height="8" Value="0" Maximum="100"
             Background="#374151" Foreground="#7C3AED" Margin="0,0,0,10">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border CornerRadius="4" Background="#374151">
                                        <Border x:Name="PART_Track" CornerRadius="4">
                                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                            Background="#7C3AED" CornerRadius="4"/>
                                        </Border>
                                    </Border>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                        <!-- Statistiche rapide -->
                        <UniformGrid Grid.Row="2" Columns="5">
                            <!-- x:Name="LblStatOpen" — numero porte aperte trovate -->
                            <Border Background="#064E3B" CornerRadius="6" Padding="8,4" Margin="0,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="APERTE" Foreground="#6EE7B7" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="LblStatOpen" Text="0" Foreground="#10B981" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- x:Name="LblStatClosed" — numero porte chiuse -->
                            <Border Background="#1F2937" CornerRadius="6" Padding="8,4" Margin="0,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CHIUSE" Foreground="#9CA3AF" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="LblStatClosed" Text="0" Foreground="#6B7280" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- x:Name="LblStatFiltered" — numero porte filtrate/firewall -->
                            <Border Background="#1C1917" CornerRadius="6" Padding="8,4" Margin="0,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="FILTRATE" Foreground="#D97706" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="LblStatFiltered" Text="0" Foreground="#F59E0B" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- x:Name="LblStatScanned" — porte totali scansionate -->
                            <Border Background="#1E1B4B" CornerRadius="6" Padding="8,4" Margin="0,0,4,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="SCANSIONATE" Foreground="#A5B4FC" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="LblStatScanned" Text="0" Foreground="#818CF8" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- x:Name="LblStatProgress" — percentuale completamento -->
                            <Border Background="#1C1917" CornerRadius="6" Padding="8,4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="PROGRESSO" Foreground="#FDA4AF" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="LblStatProgress" Text="0%" Foreground="#FB7185" FontSize="20"
                       FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>
                <!-- DataGrid risultati porte -->
                <DataGrid x:Name="DtgResults" Grid.Row="1"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          CanUserAddRows="False"
          Background="#1A1A2E"
          Foreground="#F1F5F9"
          BorderThickness="0"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#2A2A3E">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#16162A"/>
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PORTA"   Width="80"  Binding="{Binding Porta}"/>
                        <DataGridTextColumn Header="PROT."   Width="60"  Binding="{Binding Protocollo}"/>
                        <DataGridTemplateColumn Header="STATO" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{Binding StatoIcona}" Width="16" Height="16" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Stato}" Foreground="{Binding StatoColore}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="SERVIZIO"  Width="130" Binding="{Binding Servizio}"/>
                        <DataGridTextColumn Header="VERSIONE"  Width="150" Binding="{Binding VersioneServizio}"/>
                        <DataGridTextColumn Header="BANNER"    Width="200" Binding="{Binding Banner}"/>
                        <DataGridTextColumn Header="LATENZA"   Width="80"  Binding="{Binding Latenza}"/>
                        <DataGridTextColumn Header="NOTE"      Width="150" Binding="{Binding Note}"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#1A1A2E"/>
                            <Setter Property="Foreground" Value="#F1F5F9"/>
                            <Setter Property="BorderBrush" Value="#2A2A3E"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.ContextMenu>
                        <ContextMenu Background="#2A2A3E" BorderBrush="#374151">
                            <MenuItem x:Name="CmnuCopyRow"  Header="📋 Copia riga"          Foreground="#F1F5F9"/>
                            <MenuItem x:Name="CmnuCopyPort" Header="🔢 Copia numero porta"  Foreground="#F1F5F9"/>
                            <Separator Background="#374151"/>
                            <MenuItem x:Name="CmnuWhoisRow" Header="🔍 Whois lookup"        Foreground="#F1F5F9"/>
                            <MenuItem x:Name="CmnuPortInfo" Header="ℹ Dettagli porta"       Foreground="#F1F5F9"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2" Background="#16162A" BorderBrush="#374151" BorderThickness="0,1,0,0" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Port Scanner — Francesco Madonia"
                           Foreground="#4B5563" FontSize="10" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>

